// NarPulse — build settings.
// Values that are intentionally blank stay blank in this repo so secrets are
// never committed. Fill them in locally or via CI.

// ===== Supabase (substituted into Info.plist at build time) =====
SUPABASE_URL =
SUPABASE_ANON_KEY =

// ===== App identity =====
PRODUCT_BUNDLE_IDENTIFIER = io.narpulse.ios
IPHONEOS_DEPLOYMENT_TARGET = 17.0
MARKETING_VERSION = 1.0
CURRENT_PROJECT_VERSION = 1

// ===== Code signing =====
// Simulator builds are unsigned (overridden inside the .pbxproj target settings).
// Device builds use this team. Detected locally from your codesigning identity.
// If you replace this Mac or rotate certificates, update this value.
DEVELOPMENT_TEAM = 48675TY4D5
