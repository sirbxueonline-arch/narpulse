// NarPulse — build settings.
// The anon key is safe to embed in client apps — it's a public JWT gated by
// Postgres Row Level Security. The service-role key stays only in .env.local
// (gitignored) and is never bundled into a client.

// ===== Supabase (substituted into Info.plist at build time) =====
// xcconfig treats // as a comment marker, so the URL is split with an empty
// $() variable expansion to keep the parser happy.
SUPABASE_URL = https:/$()/dwmrjivixaypeengawzd.supabase.co
SUPABASE_ANON_KEY = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImR3bXJqaXZpeGF5cGVlbmdhd3pkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkwOTQ5OTQsImV4cCI6MjA5NDY3MDk5NH0.DDPYOwNjjzgMZEd3-M3I_QEOpiOZRefanMVwhmk1EPQ

// ===== App identity =====
PRODUCT_BUNDLE_IDENTIFIER = io.narpulse.ios
IPHONEOS_DEPLOYMENT_TARGET = 17.0
MARKETING_VERSION = 1.0
CURRENT_PROJECT_VERSION = 1

// ===== Code signing =====
// Simulator builds are unsigned (overridden inside the .pbxproj target settings).
// Device builds use this team. Detected locally from the existing codesigning
// identity. If you replace this Mac or rotate certificates, update this value.
DEVELOPMENT_TEAM = LKT66TJGRY
